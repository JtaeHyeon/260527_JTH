<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>

    <%
      const defaultDescription = '망자(亡者)만 입장 가능한 한국 전통 심야 주막 「저승 막걸리」의 메뉴판';
      const pageDescription = (typeof description !== 'undefined' && description) ? description : defaultDescription;
      const pageOgType = (typeof ogType !== 'undefined' && ogType) ? ogType : 'website';
      const pageOgImagePath = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : '/images/dokkaebi-makgeolli.png';
      const absoluteUrl = siteUrl + currentPath;
      const absoluteOgImage = siteUrl + pageOgImagePath;
    %>

    <!-- SEO -->
    <meta name="description" content="<%= pageDescription %>" />
    <meta name="keywords" content="저승 막걸리, 메뉴판, 한국 민속, 컨셉 식당, 다크 유머, 도깨비, 구미호, 저승사자, 막걸리, 가상 주막" />
    <meta name="author" content="저승 막걸리" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="<%= absoluteUrl %>" />

    <!-- Open Graph (페이스북·카카오톡·기타 공유 미리보기) -->
    <meta property="og:type" content="<%= pageOgType %>" />
    <meta property="og:site_name" content="저승 막걸리" />
    <meta property="og:title" content="<%= title %>" />
    <meta property="og:description" content="<%= pageDescription %>" />
    <meta property="og:url" content="<%= absoluteUrl %>" />
    <meta property="og:image" content="<%= absoluteOgImage %>" />
    <meta property="og:image:alt" content="<%= title %>" />
    <meta property="og:locale" content="ko_KR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= title %>" />
    <meta name="twitter:description" content="<%= pageDescription %>" />
    <meta name="twitter:image" content="<%= absoluteOgImage %>" />
    <meta name="twitter:image:alt" content="<%= title %>" />

    <!-- 한국어 폰트 (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Gowun+Batang:wght@400;700&family=Noto+Serif+KR:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Bootstrap 5.3 -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/css/main.css" />

    <!-- Favicon (파일 위치: public/images/favicon/) -->
    <link rel="icon" type="image/svg+xml" href="/images/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon/favicon-96x96.png" />
    <link rel="shortcut icon" href="/images/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="저승 막걸리" />
    <link rel="manifest" href="/images/favicon/site.webmanifest" />
    <meta name="theme-color" content="#14141a" />

    <!-- JS 환경 표시 — CSS의 .js 게이트(rise-from-mist 초기 invisible)가 작동하도록 즉시 토글 -->
    <script>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <nav class="site-nav" aria-label="주막 안내">
      <div class="container site-nav__inner">
        <a class="site-nav__brand" href="/">
          <span class="site-nav__lantern flicker" aria-hidden="true">◉</span>
          저승 막걸리
        </a>
        <div class="site-nav__tagline">冥府 특선</div>
      </div>
    </nav>

    <main>
      <%- include(`./${page}`) %>
    </main>

    <footer class="site-footer">
      <div class="container text-center">
        <small>본 메뉴판은 망자(亡者)에게만 유효합니다. © 저승 막걸리</small>
      </div>
    </footer>

    <script src="/js/main.js" defer></script>
  </body>
</html>
